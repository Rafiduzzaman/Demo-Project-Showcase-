# Copy to .env.local and fill values
NEXT_PUBLIC_BASE_URL=https://your-site.example.com

# Optional: SendGrid (contact form)
SENDGRID_API_KEY=
CONTACT_TO_EMAIL=you@yourdomain.com
CONTACT_FROM_EMAIL=no-reply@yourdomain.com

# Optional: Sanity CMS (if using Sanity as CMS)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Sanity configuration (optional)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: base URL for sitemap and OpenGraph (e.g. https://yourdomain.com)
NEXT_PUBLIC_BASE_URL=https://example.com

# SendGrid API key for server-side contact emails
SENDGRID_API_KEY=your_sendgrid_api_key_here
